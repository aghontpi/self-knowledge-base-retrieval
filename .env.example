# Copy to .env and adjust as needed. All values are optional; the defaults
# below match src/retrieval_assistant/config.py. .env is gitignored.

# --- Corpus location & index file -----------------------------------------
# Point this at the folder (or git repo) you want to index.
PRA_DATA_DIR=data
PRA_DB_PATH=pra.db

# --- Prose domain (markdown, text, PDF, docx, CSV, config) -----------------
PRA_PROSE_COLLECTION=prose
PRA_PROSE_MODEL=BAAI/bge-small-en-v1.5
PRA_PROSE_DIM=384

# --- Code domain (source files, notebooks) ---------------------------------
# Default is Qwen3-Embedding-0.6B (Qwen3 base, dim 1024, sentence-transformers
# native). It is asymmetric: PRA_CODE_PREFIX is prepended to the query only.
# Heavier on RAM; a small PRA_CODE_BATCH keeps peak memory bounded.
# Lighter alternative: flax-sentence-embeddings/st-codesearch-distilroberta-base
# with PRA_CODE_DIM=768 and PRA_CODE_PREFIX= (empty).
PRA_CODE_COLLECTION=code
PRA_CODE_MODEL=Qwen/Qwen3-Embedding-0.6B
PRA_CODE_DIM=1024
PRA_CODE_PREFIX=Instruct: Given a question, retrieve code or documentation that answers it\nQuery:
PRA_CODE_BATCH=8

# --- Prose chunking (character window + overlap) ---------------------------
PRA_CHUNK_SIZE=1000
PRA_CHUNK_OVERLAP=150

# --- Code chunking (line window + overlap; Python uses AST first) ----------
PRA_CODE_MAX_LINES=80
PRA_CODE_OVERLAP_LINES=10

# --- File-selection guards -------------------------------------------------
# Skip files larger than this many MB (data dumps, DBs). Binary files and
# unknown/backup suffixes are skipped regardless.
PRA_MAX_FILE_MB=1
# Use `git ls-files` when the data dir is a git repo (excludes node_modules,
# venvs, build output, gitignored files). Set to 0 to walk the tree instead.
PRA_USE_GIT=1

# --- Retrieval -------------------------------------------------------------
PRA_TOP_K=5

# --- Reranking (cross-encoder second stage) --------------------------------
# Re-scores (query, chunk) pairs on one consistent scale, so code and prose
# hits compete fairly in a single ranked list. Set PRA_RERANK=0 to disable
# (falls back to domain-grouped results). PRA_RERANK_CANDIDATES is how many
# hits are pulled per domain before reranking.
PRA_RERANK=1
PRA_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
PRA_RERANK_CANDIDATES=20

# --- Runtime (macOS / OpenMP) ----------------------------------------------
# PyTorch and pymilvus each link an OpenMP runtime; on macOS the duplicate
# aborts ingest with "OMP: Error #15" unless this is set. The Makefile targets
# set these automatically; export them yourself if you run `pra` directly.
# KMP_DUPLICATE_LIB_OK=TRUE
# OMP_NUM_THREADS=4
